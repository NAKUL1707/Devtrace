# ================================================================
# DevTrace — Environment Configuration
# Copy to .env and fill in your values
# ================================================================

# ── GitHub Integration ────────────────────────────────────────────
# Personal access token for cloning private repos (optional)
GITHUB_TOKEN=

# ── GitHub OAuth Login (Phase 3) ─────────────────────────────────
# Create OAuth App at: https://github.com/settings/developers
# Homepage URL:  http://localhost:8000
# Callback URL:  http://localhost:8000/api/v1/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# ── AI Fix Generation (Phase 3) ──────────────────────────────────
# Enables real AI-generated code fixes (pick one or both)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Notifications (Phase 4) ──────────────────────────────────────
# Slack: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
# Teams: Add Incoming Webhook connector to your Teams channel
TEAMS_WEBHOOK_URL=

# ── Session Security ──────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ── App Settings ──────────────────────────────────────────────────
APP_ENV=development
MAX_FILE_SIZE_KB=500
MAX_REPO_SIZE_MB=200
